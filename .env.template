DISCORD_LIVE_OPTIONS_WEBHOOK_URL=https://discord.com/api/webhooks/1517041868993593425/uHwPY3GBDP8cxLuhJPJaFnec0rnyEHCXEr_S5mFIwfp-eLM6qLMqRYwkH5gT11bdJdH7

########PRODUCTION ENVs

PRODUCTION=0
SHUTDOWN=0
ENABLE_ZERODHA_DERIVATIVES=0
ENABLE_ZERODHA_API=0
ENABLE_TELEGRAM_BOT=0
ENABLE_POST_MARKET=0
ENABLE_LIVE_OPTIONS=0
LIVE_OPTIONS_ONLY=0
ENABLE_INTELLIGENCE=0
ENABLE_NARRATOR=0
# REDIS_URL — required for notification-service dispatch. Default: redis://localhost:6379
# REDIS_URL=redis://localhost:6379

# Options data source:
#   "zerodha"   — Zerodha WebSocket only. Tick-accurate OI, bid/ask depth, OHLC.
#                 No Greeks or IV percentile.
#   "sensibull" — Sensibull public WebSocket only. Greeks, IV percentile, max pain.
#                 No real bid/ask depth. No auth required.
#   "both"      — Zerodha is primary (ltp, OI, depth, engine trigger).
#                 Sensibull enriches Greeks/IV on Zerodha-subscribed strikes only.
#                 Best data quality; requires valid enctoken (auto-refreshed by auth service).
OPTIONS_SOURCE=zerodha

# Optional: override expiry per symbol when zerodha_ctx is not pre-populated.
# Only needed if you run live options without ENABLE_ZERODHA_DERIVATIVES=1.
# SENSIBULL_EXPIRY_NIFTY=2026-05-08
# SENSIBULL_EXPIRY_BANKNIFTY=2026-05-07

# Google Gemini Flash API key (free from https://aistudio.google.com/apikey)
GEMINI_API_KEY=

ZERODHA_USER=<your_zerodha_user_id>
ZERODHA_PASS=<your_zerodha_password>
ZERODHA_TOTP_SECRET=<your_zerodha_totp_secret>
ZERODHA_ENC_TOKEN=<your_zerodha_enc_token>


# Healthcheck URL for dead-man's switch (used by intraday_monitor.py)
# Get a free ping URL from https://healthchecks.io/ (recommended)
HEALTHCHECK_URL=<your_healthcheck_ping_url>

########DEPLOYMENT ENVs

AWS_REGION=ap-south-1
EC2_INSTANCE_ID=<your_ec2_instance_id>
SSH_KEY_PATH=<path_to_your_pem_file>
SSH_USERNAME=ec2-user
AWS_ACCESS_KEY_ID=<your_aws_access_key_id>
AWS_SECRET_ACCESS_KEY=<your_aws_secret_access_key>

########DEVELOPMENT ENVs

DEV_INTRADAY=0
DEV_POSITIONAL=0
DEV_NOTIFY=0          # Set to 1 to send alerts in dev mode (via NOTIFICATION_CHANNEL)

# Max number of intraday analysis cycles in dev mode before stopping.
# 0 = run indefinitely (original behaviour). e.g. DEV_MAX_CYCLES=3 runs 3 cycles then stops.
DEV_MAX_CYCLES=0

# Sleep time (seconds) between dev mode cycles.
# -1 = use the same production wait logic (align to next 5-min bar).
# Default: 30 seconds.
DEV_LOOP_WAIT_TIME=30

# Log verbosity: DEBUG | INFO | WARNING | ERROR  (default: INFO)
# Set to DEBUG to see raw source data, analyser inputs, and condition evaluations.
LOG_LEVEL=INFO

# Limit how many stocks/indices are loaded in dev mode (-1 = all, default)
# Useful with run-dev-stock-intraday / run-dev-index-intraday to speed up startup
# NO_OF_STOCKS=5
# NO_OF_INDEX=2
