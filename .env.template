########TELEGRAM BOTs

TELEGRAM_INTRADAY_TOKEN=<your_intraday_bot_token>
TELEGRAM_INTRADAY_CHAT_ID=<your_intraday_chat_id>

TELEGRAM_POSITIONAL_TOKEN=<your_positional_bot_token>
TELEGRAM_POSITIONAL_CHAT_ID=<your_positional_chat_id>

# Dedicated channel for real-time options alerts (LiveOIAnalyser + LiveStraddleAnalyser)
